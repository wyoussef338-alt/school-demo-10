rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if true;
    }

    match /classScores/{classId} {
      allow read: if true;
      allow write: if true;
    }

    match /leagueTeams/{teamId} {
      allow read: if true;
      allow write: if true;
    }

    match /leagueMatches/{matchId} {
      allow read: if true;
      allow write: if true;
    }

    match /leagueVideos/{videoId} {
      allow read: if true;
      allow write: if true;
    }

    match /leagueVotes_player/{voteId} {
      allow read: if true;
      allow write: if true;
    }

    match /leagueVotes_team/{voteId} {
      allow read: if true;
      allow write: if true;
    }

    match /attendance/{recordId} {
      allow read, write: if true;
    }

    match /communications/{noteId} {
      allow read, write: if true;
    }

    match /complaints/{complaintId} {
      allow read, write: if true;
    }
  }
}
